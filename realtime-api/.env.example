# vLLM LLM Service
VLLM_MODEL=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-FP8
VLLM_PORT=8000
VLLM_GPU_MEMORY=0.75
VLLM_MAX_NUM_SEQS=8
VLLM_MAX_MODEL_LEN=131072
VLLM_TOOL_CALL_PARSER=qwen3_coder
HF_TOKEN=

# LLM Client (OpenAI-compatible)
OPENAI_BASE_URL=http://vllm-llm:8000
OPENAI_API_KEY=EMPTY
OPENAI_MODEL=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-FP8

# Magpie TTS NIM (nvidia/magpie_tts_multilingual_357m)
NGC_API_KEY=
MAGPIE_TTS_PORT=9000

# Parakeet STT
PARAKEET_PORT=9002

# TTS / STT / VAD
DEFAULT_VOICE=Mia.Calm
TTS_SPEED=125
DEFAULT_TURN_DETECTION=server_vad
DEFAULT_AEC_MODE=none
VAD_THRESHOLD=0.5
VAD_SILENCE_MS=600
VAD_PREFIX_PADDING_MS=300
