#!/usr/bin/env python3
"""CLI entry point for Neptune Graph knowledge graph operations."""

import argparse
import json
import sys
from pathlib import Path

# Add src to path for development usage
sys.path.insert(0, str(Path(__file__).parent.parent / "src"))

from neptune_graph.client import NeptuneClient
from neptune_graph.config import NeptuneGraphConfig
from neptune_graph.exceptions import NeptuneGraphError, EntityNotFoundError
from neptune_graph.operations import (
    add_entity,
    add_relationship,
    add_self_relationship,
    merge_entities,
    split_entity,
)
from neptune_graph.queries import search_entities, get_entity, get_relationships, get_summary
from neptune_graph.batch import batch_add_entities, batch_add_relationships
from neptune_graph.models import BatchInput


def _make_client(args) -> NeptuneClient:
    """Create a NeptuneClient from CLI args."""
    config = NeptuneGraphConfig(
        project=getattr(args, "project", "") or "",
        source=getattr(args, "source", "") or "",
    )
    return NeptuneClient(config)


def _parse_properties(props_str: str | None) -> dict:
    """Parse a JSON properties string."""
    if not props_str:
        return {}
    try:
        return json.loads(props_str)
    except json.JSONDecodeError as e:
        print(f"Error parsing properties JSON: {e}", file=sys.stderr)
        sys.exit(1)


def _output(data, pretty: bool = True):
    """Output data as JSON."""
    if pretty:
        print(json.dumps(data, indent=2, default=str))
    else:
        print(json.dumps(data, default=str))


# --- Command handlers ---

def cmd_add_entity(args):
    client = _make_client(args)
    props = _parse_properties(args.properties)
    result = add_entity(client, args.label, args.name, props)
    _output(result)


def cmd_add_relationship(args):
    client = _make_client(args)
    props = _parse_properties(args.properties)
    result = add_relationship(client, args.source_entity, args.target, args.type, props)
    _output(result)


def cmd_add_note(args):
    client = _make_client(args)
    result = add_self_relationship(client, args.entity, "HAS_NOTE", {"text": args.text})
    _output(result)


def cmd_get_entity(args):
    client = _make_client(args)
    result = get_entity(client, args.name)
    _output(result)


def cmd_get_relationships(args):
    client = _make_client(args)
    result = get_relationships(client, args.name, direction=args.direction)
    _output(result)


def cmd_get_summary(args):
    client = _make_client(args)
    result = get_summary(client)
    _output(result)


def cmd_search(args):
    client = _make_client(args)
    result = search_entities(client, args.query, label=args.label, limit=args.limit)
    _output(result)


def cmd_merge(args):
    client = _make_client(args)
    result = merge_entities(client, args.keep_name, args.remove_name, strategy=args.strategy)
    _output(result)


def cmd_split(args):
    client = _make_client(args)
    result = split_entity(
        client,
        args.source_entity,
        args.new_label,
        args.new_name,
        move_properties=args.move_properties,
        move_rel_types=args.move_rel_types,
    )
    _output(result)


def cmd_batch(args):
    client = _make_client(args)
    with open(args.file) as f:
        data = json.load(f)

    batch = BatchInput(**data)
    results = {}

    if batch.entities:
        entity_items = [e.model_dump() for e in batch.entities]
        results["entities"] = batch_add_entities(client, entity_items)

    if batch.relationships:
        rel_items = [r.model_dump() for r in batch.relationships]
        results["relationships"] = batch_add_relationships(client, rel_items)

    _output(results)


def cmd_query(args):
    client = _make_client(args)
    params = _parse_properties(args.parameters)
    result = client.execute(args.cypher, params if params else None)
    _output(result)


def cmd_check(args):
    client = _make_client(args)
    result = client.check()
    _output(result)
    if result.get("status") != "connected":
        sys.exit(1)


def main():
    parser = argparse.ArgumentParser(
        prog="kg",
        description="Neptune Graph knowledge graph CLI",
    )
    parser.add_argument("--project", default=None, help="Project scope (default: NEPTUNE_PROJECT env)")
    parser.add_argument("--source", default=None, help="Source provenance (default: NEPTUNE_SOURCE env)")
    subparsers = parser.add_subparsers(dest="command", required=True)

    # --- add ---
    add_parser = subparsers.add_parser("add", help="Add entities, relationships, or notes")
    add_sub = add_parser.add_subparsers(dest="add_type", required=True)

    # add entity
    add_entity_p = add_sub.add_parser("entity", help="Add an entity")
    add_entity_p.add_argument("label", help="Entity label (e.g. Person, Tool)")
    add_entity_p.add_argument("name", help="Entity name")
    add_entity_p.add_argument("--properties", default=None, help="JSON properties string")
    add_entity_p.set_defaults(func=cmd_add_entity)

    # add relationship
    add_rel_p = add_sub.add_parser("relationship", help="Add a relationship")
    add_rel_p.add_argument("source_entity", help="Source entity name")
    add_rel_p.add_argument("target", help="Target entity name")
    add_rel_p.add_argument("type", help="Relationship type (e.g. USES, DEPENDS_ON)")
    add_rel_p.add_argument("--properties", default=None, help="JSON properties string")
    add_rel_p.set_defaults(func=cmd_add_relationship)

    # add note
    add_note_p = add_sub.add_parser("note", help="Add a note (self-relationship)")
    add_note_p.add_argument("entity", help="Entity name")
    add_note_p.add_argument("text", help="Note text")
    add_note_p.set_defaults(func=cmd_add_note)

    # --- get ---
    get_parser = subparsers.add_parser("get", help="Get entities, relationships, or summary")
    get_sub = get_parser.add_subparsers(dest="get_type", required=True)

    # get entity
    get_entity_p = get_sub.add_parser("entity", help="Get entity by name")
    get_entity_p.add_argument("name", help="Entity name")
    get_entity_p.set_defaults(func=cmd_get_entity)

    # get relationships
    get_rels_p = get_sub.add_parser("relationships", help="Get entity relationships")
    get_rels_p.add_argument("name", help="Entity name")
    get_rels_p.add_argument("--direction", default="both", choices=["both", "in", "out"])
    get_rels_p.set_defaults(func=cmd_get_relationships)

    # get summary
    get_summary_p = get_sub.add_parser("summary", help="Get graph summary")
    get_summary_p.set_defaults(func=cmd_get_summary)

    # --- search ---
    search_p = subparsers.add_parser("search", help="Search entities by name")
    search_p.add_argument("query", help="Search query")
    search_p.add_argument("--label", default=None, help="Filter by label")
    search_p.add_argument("--limit", type=int, default=20, help="Max results")
    search_p.set_defaults(func=cmd_search)

    # --- merge ---
    merge_p = subparsers.add_parser("merge", help="Merge duplicate entities")
    merge_p.add_argument("keep_name", help="Entity to keep (canonical)")
    merge_p.add_argument("remove_name", help="Entity to remove (duplicate)")
    merge_p.add_argument("--strategy", default="keep_primary", help="Merge strategy")
    merge_p.set_defaults(func=cmd_merge)

    # --- split ---
    split_p = subparsers.add_parser("split", help="Split an entity")
    split_p.add_argument("source_entity", help="Entity to split from")
    split_p.add_argument("--new-label", required=True, help="Label for new entity")
    split_p.add_argument("--new-name", required=True, help="Name for new entity")
    split_p.add_argument("--move-properties", nargs="*", default=[], help="Properties to move")
    split_p.add_argument("--move-rel-types", nargs="*", default=[], help="Relationship types to move")
    split_p.set_defaults(func=cmd_split)

    # --- batch ---
    batch_p = subparsers.add_parser("batch", help="Batch add from JSON file")
    batch_p.add_argument("--file", required=True, help="Path to JSON batch file")
    batch_p.set_defaults(func=cmd_batch)

    # --- query ---
    query_p = subparsers.add_parser("query", help="Run raw openCypher query")
    query_p.add_argument("cypher", help="openCypher query string")
    query_p.add_argument("--parameters", default=None, help="JSON parameters")
    query_p.set_defaults(func=cmd_query)

    # --- check ---
    check_p = subparsers.add_parser("check", help="Health check Neptune connection")
    check_p.set_defaults(func=cmd_check)

    args = parser.parse_args()

    try:
        args.func(args)
    except EntityNotFoundError as e:
        print(json.dumps({"error": str(e)}), file=sys.stderr)
        sys.exit(1)
    except NeptuneGraphError as e:
        print(json.dumps({"error": str(e)}), file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
